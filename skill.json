{
  "name": "open-computer-use",
  "description": "Self-hosted Computer Use MCP server for desktop automation — macOS and Linux X11",
  "version": "1.1.0",
  "author": "TopherMayor",
  "repository": "https://gitea.topherymayor.com/TopherMayor/open-computer-use",
  "keywords": [
    "computer-use",
    "desktop-automation",
    "os-level",
    "self-hosted",
    "mcp",
    "pyautogui",
    "pyobjc",
    "accessibility",
    "screen-capture",
    "mouse-control",
    "keyboard-control",
    "linux-x11",
    "atspi"
  ],
  "platform": {
    "os": ["darwin", "linux"],
    "python": ">=3.10"
  },
  "plugin": {
    "manifest": ".codex-plugin/plugin.json",
    "mcpServers": ".mcp.json",
    "entrypoint": "scripts/open_computer_use_mcp_server.py",
    "launcher": "scripts/run_open_computer_use_mcp.sh"
  },
  "tools": {
    "mcp": [
      "get_app_state",
      "list_apps",
      "click",
      "drag",
      "press_key",
      "type_text",
      "scroll",
      "set_value",
      "perform_secondary_action",
      "analyze_screenshot",
      "screenshot_diff",
      "visual_click",
      "visual_locate"
    ]
  },
  "environment": {
    "required": [],
    "optional": [
      "OPEN_CU_BACKEND",
      "OPEN_CU_AUDIT_LOG",
      "OPEN_CU_MAX_ACTIONS",
      "OPEN_CU_MAX_PER_MINUTE",
      "OPEN_CU_EMERGENCY_STOP_FILE"
    ]
  },
  "permissions": {
    "required": [
      "Accessibility (macOS)",
      "Screen Recording (macOS)"
    ],
    "reason": "Local screenshots, accessibility inspection, and OS-level mouse/keyboard control require OS privacy permissions."
  }
}
